# Database settings for local docker-compose
DB_HOST=db
DB_PORT=3306

# MySQL credentials

# MySQL credentials
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=chitfund
MYSQL_USER=chituser
MYSQL_PASSWORD=chitpass

# Spring Boot datasource override (optional)
# Use when you want Spring to connect directly rather than constructing URL from pieces
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/chitfund
SPRING_DATASOURCE_USERNAME=${MYSQL_USER}
SPRING_DATASOURCE_PASSWORD=${MYSQL_PASSWORD}

# Application port mapping
APP_PORT=8080
